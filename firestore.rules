rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /rooms/{roomId} {
      // Any authenticated user can read rooms
      allow read: if request.auth != null;

      // Authenticated users can create rooms (must own it)
      allow create: if request.auth != null
        && request.resource.data.hostId == request.auth.uid;

      // Only the host can update the room document
      allow update: if request.auth != null
        && resource.data.hostId == request.auth.uid;

      // Participants sub-collection
      match /participants/{userId} {
        allow read: if request.auth != null;
        // Users can only create/update their own participant doc
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // Votes sub-collection
      match /votes/{userId} {
        allow read: if request.auth != null;
        // Users can only write their own vote
        allow create, update: if request.auth != null && request.auth.uid == userId;
        // Users can delete their own vote; host can delete all votes (for round reset)
        allow delete: if request.auth != null
          && (request.auth.uid == userId
              || get(/databases/$(database)/documents/rooms/$(roomId)).data.hostId == request.auth.uid);
      }
    }
  }
}
